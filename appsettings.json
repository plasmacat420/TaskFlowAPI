{
  /*
   * appsettings.json — Application Configuration (Production defaults)
   *
   * WHY this file:
   * ASP.NET Core uses a layered configuration system. This file provides base values.
   * appsettings.Development.json overrides specific values for local dev (like connection strings).
   * Environment variables override everything — this is how Render injects DATABASE_URL.
   *
   * Configuration loading order (last wins):
   * 1. appsettings.json (this file)
   * 2. appsettings.{Environment}.json
   * 3. Environment variables (DATABASE_URL on Render)
   * 4. Command-line arguments
   *
   * NEVER commit real secrets (passwords, API keys) to this file.
   * Use User Secrets (local dev) or environment variables (production).
   */
  "ConnectionStrings": {
    /*
     * DefaultConnection: placeholder — overridden by DATABASE_URL env var on Render.
     * For local development, set this in appsettings.Development.json.
     * Format: "Host=localhost;Database=taskflow;Username=postgres;Password=yourpassword"
     */
    "DefaultConnection": ""
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      /*
       * EF Core query logging: set to "Information" to see generated SQL in the console.
       * Useful for debugging slow queries. Set to "Warning" in production to reduce log noise.
       */
      "Microsoft.EntityFrameworkCore.Database.Command": "Warning"
    }
  },
  "AllowedHosts": "*"
}
