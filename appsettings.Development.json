{
  /*
   * appsettings.Development.json — Local Development Configuration
   *
   * WHY a separate development config:
   * Local dev needs different settings than production (local DB, verbose logging, Swagger always on).
   * This file is loaded ONLY when ASPNETCORE_ENVIRONMENT=Development (the default for `dotnet run`).
   * It is safe to commit because it contains no real secrets — use your own local DB credentials.
   *
   * For sensitive local secrets, use `dotnet user-secrets` instead of this file.
   * User secrets are stored outside the project directory and never committed to git.
   */
  "ConnectionStrings": {
    /*
     * Local PostgreSQL connection string.
     * Replace with your local PostgreSQL credentials.
     * Steps to set up locally:
     *   1. Install PostgreSQL
     *   2. Create database: CREATE DATABASE taskflow;
     *   3. Update Username/Password below
     *   4. Run: dotnet ef database update  (applies migrations)
     */
    "DefaultConnection": "Host=localhost;Database=taskflow;Username=postgres;Password=yourpassword"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Information",
      /*
       * Set to "Information" locally to see every SQL query EF Core generates.
       * This is invaluable for learning how LINQ translates to SQL and spotting N+1 query issues.
       */
      "Microsoft.EntityFrameworkCore.Database.Command": "Information"
    }
  }
}
